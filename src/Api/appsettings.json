{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "AppDbContext": "Server={MYSQL_HOST};Port={MYSQL_PORT};Database={MYSQL_DATABASE};Uid={MYSQL_USER};Pwd={MYSQL_PASSWORD};AllowPublicKeyRetrieval=True;"
  },
  // Base URL for the Slottet API. Set this to the root address of your API server (e.g., "https://localhost:5001/")
  "WebApiHostAddress": "https://localhost:5001/",
  "AllowedHosts": "*"
}
