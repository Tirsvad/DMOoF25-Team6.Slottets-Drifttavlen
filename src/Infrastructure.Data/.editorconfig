# Exclude Infrastructure.Data.Migrations from code analysis

# This file excludes the Migrations folder from code analysis (StyleCop, Roslyn analyzers, etc.)
# Place this file in the Infrastructure.Data project root.

[*.cs]
# Exclude all files in the Migrations folder from code analysis
# (relative to this .editorconfig location)
[src/Infrastructure.Data/Migrations/*.cs]
dotnet_diagnostic.SA0000.severity = none
# If using Roslyn analyzers, you may need to add additional rules here

[src/Infrastructure.Data/Migrations/*.cs]
dotnet_diagnostic.IDE*.severity= none
dotnet_diagnostic.CA*.severity = none
