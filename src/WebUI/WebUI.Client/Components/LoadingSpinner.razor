<svg width="80" height="80" viewBox="0 0 80 80">
  <!-- Spinner circle -->
  <circle
    cx="40"
    cy="40"
    r="20"
    fill="none"
          stroke="#888"
    stroke-width="6"
    stroke-linecap="round"
    stroke-dasharray="47 188"
  >
    <animateTransform
      attributeName="transform"
      type="rotate"
      from="0 40 40"
      to="360 40 40"
      dur="1s"
      repeatCount="indefinite"
    />
  </circle>

  <!-- Centered text -->
  <text
    x="50%"
    y="50%"
    text-anchor="middle"
    dominant-baseline="middle"
    font-size="10"
    fill="currentColor"
  >
    Indlæser...
  </text>
</svg>

