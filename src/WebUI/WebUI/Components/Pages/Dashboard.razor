@* UC001 - Dashboard for all residents overview and status *@
@*UC001 Task - Low Fi prototype for first iteration of prototype*@
@page "/dashboard"
@rendermode InteractiveServer
@using Domain.Enums
@using Domain.Entities
@using WebUI.Components.Residents

<PageTitle>Dashboard</PageTitle>

<main>
  <h1 class="mb-4">Slottets Dashboard</h1>
  <section aria-label="Resident Overview">
        <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var resident in _residents)
        {
          
            <div class="col">
                    <ResidentCard Initials="@resident.Initials" TrafficLight="@(resident.TrafficLight ?? TrafficLight.Green)" LastUpdated="Just now" />
                </div>          

        }
        </div>
    </section>
</main>





@code 
{
    private List<Resident> _residents =
    [
       new() { Id = Guid.NewGuid(), Initials = "AB", TrafficLight = TrafficLight.Green },
       new() { Id = Guid.NewGuid(), Initials = "TS", TrafficLight = TrafficLight.Yellow },
       new() { Id = Guid.NewGuid(), Initials = "MK", TrafficLight = TrafficLight.Red },
    ];
   
    //TODO: Replace with real timestamp in LastUpdated and update it when traffic light changes

}
