@* UC001 - Dashboard for all residents overview and status *@
@*UC001 Task - Low Fi prototype for first iteration of prototype*@

@layout DashboardLayout
@page "/dashboard"
@rendermode InteractiveAuto
@using Domain.Enums
@using Domain.Entities
@using WebUI.Client.Components.Layout
@using WebUI.Client.Components.Residents
@inject Core.Interfaces.Services.IResidentService ResidentService

<PageTitle>Dashboard</PageTitle>

<main>
    <section aria-label="Resident Overview" class="dashboard-grid container-fluid min-vh-100 d-flex align-items-center">
        <div class="row g-3 row-cols-1 row-cols-md-4">

            @foreach (var resident in _residents)
            {
                <div class="col">
                    @*@ Korrekt *@
                    @* <ResidentCard Resident="resident" /> *@
                </div>
            }
        </div>
    </section>
</main>
